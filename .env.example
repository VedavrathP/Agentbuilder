# --- OpenAI ---
OPENAI_API_KEY=sk-...
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# --- Postgres ---
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=orchestra
POSTGRES_DB=orchestra
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend uses the asyncpg driver via SQLAlchemy for app data
# In docker-compose, host is "db". From your host machine, use localhost:5433.
DATABASE_URL=postgresql+asyncpg://orchestra:orchestra@db:5432/orchestra
# LangGraph checkpointer uses psycopg3 (plain postgresql://)
LANGGRAPH_DATABASE_URL=postgresql://orchestra:orchestra@db:5432/orchestra

# --- Redis ---
# In docker-compose, host is "redis". From your host machine, use localhost:6380.
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Telegram (optional at boot; can be set in UI later) ---
# Token used by the default polling worker. Leave empty to disable telegram at boot.
TELEGRAM_BOT_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
